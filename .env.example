PORT=5175
HOST=127.0.0.1

# Optional integrations. The backend runs without these, but live voice needs Deepgram.
OPENAI_API_KEY=
GEMINI_API_KEY=
GEMINI_TEXT_MODEL=gemini-3.5-flash
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image
DEEPGRAM_API_KEY=
DEEPGRAM_TTS_MODEL=aura-2-thalia-en
PIKA_API_KEY=

# Deepgram live STT mode. Only "nova" and "flux" are recognized; any other
# value (including a typo) falls back to "nova" so a bad config can never
# silently disable voice. Flux is the conversational/turn-taking model;
# Nova is the existing general Listen model already used in production.
DEEPGRAM_STT_MODE=nova
DEEPGRAM_STT_MODEL=flux-general-en
# Flux end-of-turn tuning. These are sent as literal Deepgram query params,
# so an unrecognized name here will make Deepgram refuse the connection
# (closes immediately with code 1006) rather than ignore it. Confirmed
# valid against the live API on 2026-06-21 with model=flux-general-en.
DEEPGRAM_EOT_THRESHOLD=0.7
DEEPGRAM_EAGER_EOT_THRESHOLD=0.6
DEEPGRAM_EOT_TIMEOUT_MS=5000

# Set to true when the external integrations are wired.
USE_OPENAI=false
USE_GEMINI_IMAGE=false
USE_GEMINI_TEXT=true
USE_DEEPGRAM=false
USE_PIKA=false
